# Integration test credentials (copy to .env; .env is gitignored)
# Run all integration tests: npm run test:integration
# Run one provider: PROVIDER=cloudflare npm run test:integration

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_MODEL=cf/moonshotai/kimi-k2.6

# Anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_SONNET_MODEL=
# ANTHROPIC_HAIKU_MODEL=

# OpenRouter
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Gemini (either key name works)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=

# xAI
XAI_API_KEY=
# XAI_MODEL=

# Ollama (local)
OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=

# AWS Bedrock (uses standard AWS SDK credential chain when vars are unset)
AWS_REGION=
# BEDROCK_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# BEDROCK_MODEL=
